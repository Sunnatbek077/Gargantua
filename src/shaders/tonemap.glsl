/**
 * ═══════════════════════════════════════════════════════════════════════════════
 * GARGANTUA — Tone Mapping & Post Effects
 * ═══════════════════════════════════════════════════════════════════════════════
 *
 * HDR → SDR konversiya va yakuniy rang ishlov berish.
 *
 * Formulalar:
 *   #26 — ACES Filmic tone mapping
 *   #36 — Luminance (BT.709)
 *   #37 — Gamma korreksiya (sRGB 2.2)
 * ═══════════════════════════════════════════════════════════════════════════════
 */


// ─────────────────────────────────────────────────────────────────────────────
// I. LUMINANCE
// ─────────────────────────────────────────────────────────────────────────────
// ── Formula #36: ITU-R BT.709 ──

float calcLuminance(vec3 c) {
  return dot(c, vec3(0.2126, 0.7152, 0.0722));
}


// ─────────────────────────────────────────────────────────────────────────────
// II. ACES TONE MAPPING
// ─────────────────────────────────────────────────────────────────────────────
// ── Formula #26 ──

vec3 acesToneMap(vec3 x) {
  return clamp(
    (x * (2.51 * x + 0.03)) / (x * (2.43 * x + 0.59) + 0.14),
    0.0, 1.0
  );
}


// ─────────────────────────────────────────────────────────────────────────────
// III. GAMMA KORREKSIYA
// ─────────────────────────────────────────────────────────────────────────────
// ── Formula #37: sRGB gamma 2.2 ──

vec3 gammaCorrect(vec3 c) {
  return pow(max(c, vec3(0.0)), vec3(1.0 / 2.2));
}


// ─────────────────────────────────────────────────────────────────────────────
// IV. VIGNETTE — INTERSTELLAR IMAX kadr hissi
// ─────────────────────────────────────────────────────────────────────────────

float vignette(vec2 uv) {
  vec2 d = abs(uv - 0.5) * 2.0;
  d = pow(d, vec2(0.8));
  float dist = pow(d.x + d.y, 1.0 / 0.8);
  return 1.0 - smoothstep(0.3, 1.0, dist) * 0.55;
}


// ─────────────────────────────────────────────────────────────────────────────
// V. FILM GRAIN — 70mm IMAX donadorlik
// ─────────────────────────────────────────────────────────────────────────────
// ── Formula #29 ──

float filmGrain(vec2 uv, float time) {
  return (fract(sin(dot(uv + fract(time * 0.71), vec2(12.9898, 78.233))) * 43758.5453) - 0.5) * 0.12;
}
